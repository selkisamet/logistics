# ==== API (apps/api) ====
# PostgreSQL bağlantısı
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lojistik?schema=public"

# JWT
JWT_SECRET="degistir-bu-uzun-rastgele-bir-deger-olsun"
JWT_EXPIRES_IN="1d"

# Sunucu
API_PORT=3000
# CORS için web origin
WEB_ORIGIN="http://localhost:5173"

# Dosya depolama (local | s3)
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./uploads"

# AI / OCR (pluggable) — şimdilik opsiyonel, Faz 5'te kullanılacak
OCR_PROVIDER="claude"
ANTHROPIC_API_KEY=""

# ==== WEB (apps/web) ====
# Vite env değişkenleri VITE_ önekiyle
VITE_API_URL="http://localhost:3000"

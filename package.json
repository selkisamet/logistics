{
  "name": "lojistik-depolama",
  "version": "0.1.0",
  "private": true,
  "description": "Tesellüm & Depo Yönetim Sistemi (WMS) - 3PL lojistik mal kabul, depolama ve dağıtım uygulaması",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "shared:build": "pnpm --filter @lojistik/shared build",
    "api:dev": "pnpm --filter @lojistik/api dev",
    "web:dev": "pnpm --filter @lojistik/web dev",
    "db:migrate": "pnpm --filter @lojistik/api prisma migrate dev",
    "db:seed": "pnpm --filter @lojistik/api db:seed",
    "db:studio": "pnpm --filter @lojistik/api prisma studio",
    "pg:start": "\".tools/pgsql/bin/pg_ctl\" -D .tools/pgdata -l .tools/pg.log -o \"-p 5432\" start",
    "pg:stop": "\".tools/pgsql/bin/pg_ctl\" -D .tools/pgdata stop",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
